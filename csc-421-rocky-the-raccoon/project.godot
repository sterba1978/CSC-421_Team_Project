; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Rocky_The_Raccoon"
run/main_scene="uid://d2u1r51rcc0ay"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

DialogueManager="*uid://c3rodes2l3gxb"
MusicManager="*res://scene/music_manager.gd"
SceneTransitionState="*res://scene/scene_transition_state.gd"

[dialogue_manager]

runtime/balloon_path="res://dialogue/testing/balloon.tscn"

[display]

window/stretch/mode="viewport"

[editor_plugins]

enabled=PackedStringArray("res://addons/TileMapLayer3D/plugin.cfg", "res://addons/dialogue_manager/plugin.cfg", "res://addons/gdscript-templates/plugin.cfg", "res://addons/grid_map_layer/plugin.cfg")

[internationalization]

locale/translations_pot_files=PackedStringArray("res://dialogue/testing/testdialogue.dialogue")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
